// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String               @id @default(cuid())
  username       String               @unique
  oidcSub        String               @unique
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  commands       Command[]
  sketches       Sketch[]
  collaborations SketchCollaborator[]
}

model Sketch {
  id        String   @id @default(cuid())
  name      String
  color     String?
  positionX Float?
  positionY Float?
  zoom      Float?
  public    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner         User                 @relation(fields: [ownerId], references: [id])
  ownerId       String
  commands      Command[]
  collaborators SketchCollaborator[]
}

model Command {
  id       String   @id @default(cuid())
  ts       DateTime @default(now())
  uid      String
  type     String
  sid      String
  data     String
  sketchId String
  user     User     @relation(fields: [uid], references: [id])
  sketch   Sketch   @relation(fields: [sketchId], references: [id])
}

model SketchCollaborator {
  id        String   @id @default(cuid())
  sketchId  String
  userId    String
  role      String   @default("collaborator")
  createdAt DateTime @default(now())
  sketch    Sketch   @relation(fields: [sketchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sketchId, userId])
}
